# Public — Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public — external Ball Mastery course (Strive OS launches into this)
NEXT_PUBLIC_COURSE_URL=

# Server — GoHighLevel core
GHL_API_KEY=
GHL_LOCATION_ID=
GHL_WEBHOOK_URL=
GHL_WEBHOOK_SECRET=

# Server — GoHighLevel Social Planner (TikTok auto-poster)
#   GHL_TIKTOK_ACCOUNT_ID is the socialAccountId returned by GHL once you
#   connect your TikTok identity in Social Planner.
GHL_TIKTOK_ACCOUNT_ID=

# Server — Stripe (course + package payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Server — AI strategist (swap into /api/ai/generate)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Server — AI ad rendering
#   Higgsfield: text-to-video (the visuals)
#   ElevenLabs: voiceover
HIGGSFIELD_API_KEY=
ELEVENLABS_API_KEY=

# Server — daily auto-poster cron protection
#   Required on /api/cron/daily-tiktok as ?key=<value>. Any random string.
CRON_SECRET=
