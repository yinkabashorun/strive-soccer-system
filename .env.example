# Public — Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public — base URL of this Strive OS deployment. Used to build Stripe
# success/cancel URLs when a request doesn't carry an Origin header
# (server-side requests, webhooks).
NEXT_PUBLIC_APP_URL=https://strive-soccer-system.vercel.app

# Public — external Ball Mastery course (Strive OS launches into this)
NEXT_PUBLIC_COURSE_URL=

# Server — GoHighLevel · CRM + Social Planner.
# - Dribbling course buyer is tagged with "dribbling-course-buyer" via
#   /api/ghl/dribbling-course-buyer.
# - GHL webhook lands at /api/ghl/webhook.
GHL_API_KEY=
GHL_LOCATION_ID=
GHL_WEBHOOK_URL=
GHL_WEBHOOK_SECRET=
# Comma-separated GHL social account IDs the planner will post to
GHL_SOCIAL_ACCOUNT_IDS=
# Two HH:mm slots (24h, location-local) for the 2x/day cadence
GHL_DAILY_SLOTS=11:00,19:00

# Server — Stripe · $97 dribbling course checkout.
# POST /api/checkout/dribbling-course creates a Checkout Session.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Server — Anthropic (powers the AI content engine + dribbling-course UGC)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# Server — ElevenLabs (voiceovers)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Server — Fal.ai (text-to-video UGC)
# REST queue API. Auth header is `Authorization: Key <FAL_KEY>`.
# Default model is kling-video v1.6 standard text-to-video; override with
# FAL_MODEL if you prefer minimax/video-01 or another fal.ai model.
FAL_KEY=
FAL_MODEL=fal-ai/kling-video/v1.6/standard/text-to-video

# Server — Autopilot cron (Vercel sends Authorization: Bearer <CRON_SECRET>)
# The cron runs weekly (vercel.json) and produces 14 posts = 2x/day for 7 days.
CRON_SECRET=
