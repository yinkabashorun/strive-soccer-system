# Public — Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public — external Ball Mastery course (Strive OS launches into this)
NEXT_PUBLIC_COURSE_URL=

# Server — GoHighLevel (Social Planner + CRM)
GHL_API_KEY=
GHL_LOCATION_ID=
GHL_WEBHOOK_URL=
GHL_WEBHOOK_SECRET=
# Comma-separated GHL social account IDs the planner will post to
GHL_SOCIAL_ACCOUNT_IDS=
# Two HH:mm slots (24h, location-local) for the 2x/day cadence
GHL_DAILY_SLOTS=11:00,19:00

# Server — Stripe (course + package payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Server — Anthropic (powers the AI content engine)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# Server — ElevenLabs (voiceovers)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Server — Higgsfield (hyper-realistic UGC creator videos)
# Higgsfield ships an MCP server, not a REST API. Pick ONE of the two modes:
#
# (A) MCP over stdio — recommended. Strive OS spawns the server per call.
#     The command/args below match the typical "npx -y <package>" install.
HIGGSFIELD_MCP_COMMAND=npx
HIGGSFIELD_MCP_ARGS=-y,@higgsfield/mcp-server
HIGGSFIELD_API_KEY=
# Override tool names only if your version of the MCP server uses different ones.
HIGGSFIELD_GENERATE_TOOL=generate_video
HIGGSFIELD_POLL_TOOL=get_generation
#
# (B) CLI fallback — if you installed a one-shot binary instead.
# HIGGSFIELD_CLI=/usr/local/bin/higgsfield

# Server — Autopilot cron (Vercel sends Authorization: Bearer <CRON_SECRET>)
# The cron runs weekly (vercel.json) and produces 14 posts = 2x/day for 7 days.
CRON_SECRET=
