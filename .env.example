# Public — Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public — external Ball Mastery course (Strive OS launches into this)
NEXT_PUBLIC_COURSE_URL=

# Server — GoHighLevel (Social Planner + CRM)
GHL_API_KEY=
GHL_LOCATION_ID=
GHL_WEBHOOK_URL=
GHL_WEBHOOK_SECRET=
# Comma-separated GHL social account IDs the planner will post to
GHL_SOCIAL_ACCOUNT_IDS=
# Two HH:mm slots (24h, location-local) for the 2x/day cadence
GHL_DAILY_SLOTS=11:00,19:00

# Server — Stripe (course + package payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Server — Anthropic (powers the AI content engine)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# Server — ElevenLabs (voiceovers)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Server — Fal.ai (text-to-video UGC)
# REST queue API. Auth header is `Authorization: Key <FAL_KEY>`.
# Default model is kling-video v1.6 standard text-to-video; override with
# FAL_MODEL if you prefer minimax/video-01 or another fal.ai model.
FAL_KEY=
FAL_MODEL=fal-ai/kling-video/v1.6/standard/text-to-video

# Server — Autopilot cron (Vercel sends Authorization: Bearer <CRON_SECRET>)
# The cron runs weekly (vercel.json) and produces 14 posts = 2x/day for 7 days.
CRON_SECRET=

# Public — base URL of this Strive OS app (used to build Stripe success_url
# / cancel_url when a request doesn't include an Origin header).
NEXT_PUBLIC_APP_URL=http://localhost:3000
