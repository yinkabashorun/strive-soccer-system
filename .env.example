# Public — Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public — base URL of this app (used to build Stripe success/cancel
# URLs when a request doesn't carry an Origin header — e.g. server-side
# requests, or webhooks).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public — external Ball Mastery course (Strive OS launches into this)
NEXT_PUBLIC_COURSE_URL=

# Server — GoHighLevel · CRM. The dribbling-course buyer is tagged with
# "dribbling-course-buyer" via /api/ghl/dribbling-course-buyer.
GHL_API_KEY=
GHL_LOCATION_ID=
GHL_WEBHOOK_URL=
GHL_WEBHOOK_SECRET=

# Server — Stripe · $97 dribbling course checkout.
# POST /api/checkout/dribbling-course creates a Checkout Session.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Server — AI providers (used by /api/ai/generate)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7
OPENAI_API_KEY=
